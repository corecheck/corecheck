          "refId": "C",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Issue trends",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Distribution of currently open issues across GitHub labels.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 22},
      "id": 15,
      "options": {
        "displayLabels": ["name"],
        "legend": {"displayMode": "table", "placement": "right", "values": ["value"]},
        "pieType": "pie",
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "SELECT AVG(\"bitcoin.bitcoin.issues.open.by_label\") FROM \"${telemetry_namespace}\" GROUP BY label ORDER BY AVG() DESC LIMIT 20",
          "hide": false,
          "id": "",
          "matchExact": true,
          "metricEditorMode": 1,
          "metricQueryType": 1,
          "queryMode": "Metrics",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Open issues by label",
      "type": "piechart"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Distribution of closed issues across GitHub labels.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 22},
      "id": 16,
      "options": {
