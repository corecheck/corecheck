          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Unique issue authors",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Running totals of open, closed, and all issues. The slope of the total line shows new issues opened during the selected window.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "id": 14,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "label": "open",
          "metricName": "bitcoin.bitcoin.issues.open",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        },
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "label": "closed",
          "metricName": "bitcoin.bitcoin.issues.closed",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
