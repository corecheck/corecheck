      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 18},
      "id": 12,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "/^count$/", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
