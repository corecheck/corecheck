      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "metricName": "bitcoin.bitcoin.issues.open",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Open issues",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Number of issues closed during the selected time window (net change in the closed counter).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 18},
      "id": 12,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["delta"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "metricName": "bitcoin.bitcoin.issues.closed",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Closed issues (period)",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Unique GitHub users who have opened an issue (current snapshot).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "purple", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 18},
      "id": 13,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "metricName": "bitcoin.bitcoin.issues.unique_users",
          "namespace": "${telemetry_namespace}",
