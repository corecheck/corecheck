      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "id": 14,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "label": "open",
          "metricName": "bitcoin.bitcoin.issues.open",
          "namespace": "${telemetry_namespace}",
          "period": "",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Open issues trend",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Labels applied to issues in the selected time range.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "id": 15,
      "options": {
        "displayLabels": ["name"],
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value"]},
        "pieType": "pie",
        "reduceOptions": {"calcs": ["max"], "fields": "", "values": true},
        "sort": "desc",
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter source_type = \"issue\" and event_type = \"labeled\"\n| fields jsonParse(@message) as msg\n| fields msg.labels as labelsList\n| unnest labelsList into label\n| stats count(*) as Count by label as Label\n| sort Count desc\n| display Label, Count\n| limit 15",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${github_events_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}",
