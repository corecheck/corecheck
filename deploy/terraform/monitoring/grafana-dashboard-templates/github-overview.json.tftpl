          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "SELECT SUM(\"bitcoin.bitcoin.issues.comments_period\") FROM \"${telemetry_namespace}\" GROUP BY issue ORDER BY SUM() DESC LIMIT 20",
          "hide": false,
          "id": "",
          "matchExact": true,
