        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "fields @timestamp, event_type\n| filter source_type = \"pull\"\n| stats count(*) as Count by event_type, bin($__interval)",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${github_events_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}",
          "statsGroups": ["event_type", "bin($__interval)"]
        }
      ],
      "title": "Pull request activity",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
