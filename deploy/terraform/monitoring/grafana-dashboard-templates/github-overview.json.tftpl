            "includeByName": {},
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "type": "piechart"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Issues with the most comments in the selected time range. Click a row to open the issue on GitHub.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": false,
            "footer": {"reducers": []},
            "inspect": false,
            "minWidth": 50,
            "wrapText": true
          },
          "links": [
            {
              "title": "Open on GitHub",
              "url": "https://github.com/bitcoin/bitcoin/issues/$${__data.fields.Issue}"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "red", "value": 80}]
          }
