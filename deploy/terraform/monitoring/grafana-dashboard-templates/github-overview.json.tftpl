{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": {
          "limit": 100,
          "matchAny": false,
          "tags": [],
          "type": "dashboard"
        }
      }
    ]
  },
  "description": "Migrated from DataDog dashboard ${datadog_dashboard_id} (${datadog_dashboard_title}, ${datadog_widget_count} widgets) for ${route}. Assumes GitHub stats metrics are published to CloudWatch custom metrics in the ${telemetry_namespace} namespace.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Pull Requests",
      "type": "row"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Current total number of open pull requests.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "metricName": "bitcoin.bitcoin.pulls.open",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Open pull requests",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Number of pull requests merged during the selected time window (net change in the merged counter).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["delta"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "metricName": "bitcoin.bitcoin.pulls.merged",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Merged pull requests (period)",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Unique GitHub users who have authored a merged pull request (current snapshot).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "purple", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "metricName": "bitcoin.bitcoin.pulls.unique_authors",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Unique PR authors",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Running total of all pull requests ever created. The slope shows how many new PRs were opened during the selected window.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 4,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "label": "open",
          "metricName": "bitcoin.bitcoin.pulls.open",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "A",
          "region": "${compute_region}",
          "statistic": "Average"
        },
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "label": "merged",
          "metricName": "bitcoin.bitcoin.pulls.merged",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "B",
          "region": "${compute_region}",
          "statistic": "Average"
        },
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {},
          "label": "total",
          "metricName": "bitcoin.bitcoin.pulls.total",
          "namespace": "${telemetry_namespace}",
          "period": "86400",
          "queryMode": "Metrics",
          "metricEditorMode": 0,
          "metricQueryType": 0,
          "matchExact": true,
          "refId": "C",
          "region": "${compute_region}",
          "statistic": "Average"
        }
      ],
      "title": "Pull request trends",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Distribution of currently open pull requests across GitHub labels.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 5},
      "id": 5,
      "options": {
        "displayLabels": ["name"],
        "legend": {"displayMode": "table", "placement": "right", "values": ["value"]},
        "pieType": "pie",
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "SELECT AVG(\"bitcoin.bitcoin.pulls.open.by_label\") FROM \"${telemetry_namespace}\" GROUP BY label ORDER BY AVG() DESC LIMIT 20",
          "hide": false,
          "id": "",
          "matchExact": true,
          "metricEditorMode": 1,
          "metricQueryType": 1,
          "queryMode": "Metrics",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Open pull requests by label",
      "type": "piechart"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Distribution of merged pull requests across GitHub labels.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 5},
      "id": 6,
      "options": {
        "displayLabels": ["name"],
        "legend": {"displayMode": "table", "placement": "right", "values": ["value"]},
        "pieType": "pie",
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "SELECT AVG(\"bitcoin.bitcoin.pulls.merged.by_label\") FROM \"${telemetry_namespace}\" GROUP BY label ORDER BY AVG() DESC LIMIT 20",
          "hide": false,
          "id": "",
          "matchExact": true,
          "metricEditorMode": 1,
          "metricQueryType": 1,
          "queryMode": "Metrics",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Merged pull requests by label",
      "type": "piechart"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Pull requests with the most comments and reviews in the last 30 days. Click a row to open the PR on GitHub.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": false,
            "inspect": false
          },
          "links": [
            {
              "title": "Open on GitHub",
              "url": "https://github.com/bitcoin/bitcoin/pull/$${__data.fields.pull}"
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "id": 7,
      "options": {
        "footer": {"show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "bitcoin.bitcoin.pulls.comments_period"}]
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "SELECT SUM(\"bitcoin.bitcoin.pulls.comments_period\") FROM \"${telemetry_namespace}\" GROUP BY pull ORDER BY SUM() DESC LIMIT 20",
          "hide": false,
          "id": "",
          "matchExact": true,
          "metricEditorMode": 1,
          "metricQueryType": 1,
          "queryMode": "Metrics",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Most commented pull requests (last 30 days)",
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
      "id": 200,
      "title": "Issues",
      "type": "row"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Current total number of open issues.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "orange", "value": null}]
