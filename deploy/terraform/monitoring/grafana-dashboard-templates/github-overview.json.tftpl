    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34},
      "id": 300,
      "title": "Activity Stream",
      "type": "row"
    },
    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "normal"}
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 35},
      "id": 18,
      "options": {
