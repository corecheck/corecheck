          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "id": 17,
      "options": {
        "footer": {"show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Comments"}]
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "fields number as Issue, title as Title | filter source_type = \"issue\" and event_type = \"commented\" | stats count(*) as Comments by Issue, Title | sort Comments desc | limit 20",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${github_events_log_group}"}],
          "queryMode": "Logs",
