      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "id": 17,
      "options": {
        "footer": {"show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "bitcoin.bitcoin.issues.comments_period"}]
