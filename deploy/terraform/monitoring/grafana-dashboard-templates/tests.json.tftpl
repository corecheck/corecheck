{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": {"limit": 100, "matchAny": false, "tags": [], "type": "dashboard"}
      }
    ]
  },
  "description": "Bitcoin Core test suite performance over time. Functional and unit test durations are stored in CloudWatch Logs (${test_results_log_group}) on each master commit.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Overview",
      "type": "row"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Number of distinct functional tests seen in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/^cnt$/", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"functional\" | stats count_distinct(test_name) as cnt",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Functional tests",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Number of distinct unit tests (ctest suites) seen in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/^cnt$/", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"unit\" | stats count_distinct(test_name) as cnt",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Unit tests",
      "type": "stat"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Sum of all functional test durations per day — a proxy for total test suite CPU cost.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 1},
      "id": 3,
      "options": {
        "legend": {"calcs": [], "displayMode": "hidden", "placement": "bottom"},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"functional\" | stats sum(duration_s) as total_duration_s by bin(1d)",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Functional suite total duration / day",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Sum of all unit test durations per day.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 1},
      "id": 4,
      "options": {
        "legend": {"calcs": [], "displayMode": "hidden", "placement": "bottom"},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"unit\" | stats sum(duration_s) as total_duration_s by bin(1d)",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Unit suite total duration / day",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 200,
      "title": "Functional Tests — Rankings",
      "type": "row"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Average duration of functional tests over the selected time range, sorted slowest first.",
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "test_name"},
            "properties": [{"id": "displayName", "value": "Test"}]
          },
          {
            "matcher": {"id": "byName", "options": "avg_duration_s"},
            "properties": [{"id": "displayName", "value": "Avg duration (s)"}, {"id": "custom.width", "value": 140}]
          },
          {
            "matcher": {"id": "byName", "options": "max_duration_s"},
            "properties": [{"id": "displayName", "value": "Max duration (s)"}, {"id": "custom.width", "value": 140}]
          }
        ]
      },
      "gridPos": {"h": 14, "w": 8, "x": 0, "y": 6},
      "id": 201,
      "options": {"showHeader": true, "sortBy": [{"desc": true, "displayName": "Avg duration (s)"}]},
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"functional\" | stats avg(duration_s) as avg_duration_s, max(duration_s) as max_duration_s by test_name | sort avg_duration_s desc | limit 25",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}"
        }
      ],
      "title": "Slowest functional tests (top 25)",
      "type": "table"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Tests whose average duration has increased the most. Compares recent 30-day average against the full dashboard time range average. A positive change means the test has gotten slower.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "test_name"},
            "properties": [{"id": "displayName", "value": "Test"}]
          },
          {
            "matcher": {"id": "byName", "options": "hist_avg"},
            "properties": [{"id": "displayName", "value": "Historical avg (s)"}, {"id": "unit", "value": "s"}, {"id": "custom.width", "value": 140}]
          },
          {
            "matcher": {"id": "byName", "options": "recent_avg"},
            "properties": [{"id": "displayName", "value": "Recent avg (s)"}, {"id": "unit", "value": "s"}, {"id": "custom.width", "value": 120}]
          },
          {
            "matcher": {"id": "byName", "options": "change_s"},
            "properties": [{"id": "displayName", "value": "Change (s)"}, {"id": "unit", "value": "s"}, {"id": "custom.width", "value": 100},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}]
          }
        ]
      },
      "gridPos": {"h": 14, "w": 8, "x": 8, "y": 6},
      "id": 202,
      "options": {"showHeader": true},
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"functional\" | stats avg(duration_s) as hist_avg by test_name",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}"
        },
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"functional\" | stats avg(duration_s) as recent_avg by test_name",
          "hide": false,
          "id": "B",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "B",
          "region": "${compute_region}",
          "timeRange": {"from": "now-30d", "to": "now"}
        }
      ],
      "title": "Biggest regressions (functional)",
      "transformations": [
        {"id": "joinByField", "options": {"byField": "test_name", "mode": "outer"}},
        {"id": "calculateField", "options": {"alias": "change_s", "binary": {"left": "recent_avg", "operator": "-", "right": "hist_avg"}, "mode": "binary"}},
        {"id": "filterByValue", "options": {"filters": [{"config": {"id": "greater", "options": {"value": 0}}, "fieldName": "change_s"}], "match": "all", "type": "include"}},
        {"id": "sortBy", "options": {"fields": [{"desc": true, "displayName": "change_s"}]}},
        {"id": "limit", "options": {"limitField": 20}}
      ],
      "type": "table"
    },

    {
      "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
      "description": "Tests whose average duration has decreased the most. Compares recent 30-day average against the full dashboard time range average.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
