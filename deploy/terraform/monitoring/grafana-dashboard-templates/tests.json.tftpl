        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "dimensions": {
            "JobQueue": "${coverage_queue_name}"
          },
          "label": "runnable",
          "metricName": "RunnableJobs",
          "namespace": "AWS/Batch",
          "period": "300",
          "queryMode": "Metrics",
