          },
          {
            "matcher": {"id": "byName", "options": "recent_avg"},
            "properties": [{"id": "displayName", "value": "Recent avg (s)"}, {"id": "unit", "value": "s"}, {"id": "custom.width", "value": 120}]
          },
          {
            "matcher": {"id": "byName", "options": "change_s"},
            "properties": [{"id": "displayName", "value": "Change (s)"}, {"id": "unit", "value": "s"}, {"id": "custom.width", "value": 100},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 0}]}}]
          }
        ]
      },
      "gridPos": {"h": 14, "w": 8, "x": 16, "y": 6},
      "id": 203,
      "options": {"showHeader": true},
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"functional\" | stats avg(duration_s) as hist_avg by test_name",
          "hide": false,
          "id": "A",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "A",
          "region": "${compute_region}"
        },
        {
          "datasource": {"type": "cloudwatch", "uid": "corecheck-cloudwatch"},
          "expression": "filter test_type = \"functional\" | stats avg(duration_s) as recent_avg by test_name",
          "hide": false,
          "id": "B",
          "logGroups": [{"name": "${test_results_log_group}"}],
          "queryMode": "Logs",
          "refId": "B",
          "region": "${compute_region}",
          "timeRange": {"from": "now-30d", "to": "now"}
        }
      ],
      "title": "Biggest speedups (functional)",
      "transformations": [
        {"id": "joinByField", "options": {"byField": "test_name", "mode": "outer"}},
        {"id": "calculateField", "options": {"alias": "change_s", "binary": {"left": "recent_avg", "operator": "-", "right": "hist_avg"}, "mode": "binary"}},
        {"id": "filterByValue", "options": {"filters": [{"config": {"id": "lower", "options": {"value": 0}}, "fieldName": "change_s"}], "match": "all", "type": "include"}},
        {"id": "sortBy", "options": {"fields": [{"desc": false, "displayName": "change_s"}]}},
        {"id": "limit", "options": {"limitField": 20}}
      ],
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 20},
      "id": 300,
